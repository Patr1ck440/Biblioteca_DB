<!DOCTYPE html>
<html>
  <head>
    <title>Biblioteca</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application" %>
  </head>
  <body>
    <nav style="background:#2c3e50;padding:10px 20px;color:white;display:flex;justify-content:space-between;align-items:center">
      <a href="/" style="color:white;text-decoration:none;font-size:20px;font-weight:bold">📚 Biblioteca</a>
      <div style="display:flex;gap:20px">
        <% if logged_in? %>
          <%= link_to "Cărți", books_path, style: "color:white;text-decoration:none" %>
          <%= link_to "Împrumuturi", loans_path, style: "color:white;text-decoration:none" %>
          <% if admin_or_librarian? %>
            <%= link_to "Utilizatori", users_path, style: "color:white;text-decoration:none" %>
          <% end %>
          <%= link_to "Ieșire (#{current_user.name})", logout_path, data: { turbo_method: :delete }, style: "color:white;text-decoration:none" %>
        <% else %>
          <%= link_to "Autentificare", login_path, style: "color:white;text-decoration:none" %>
          <%= link_to "Înregistrare", new_user_path, style: "color:white;text-decoration:none" %>
        <% end %>
      </div>
    </nav>

    <div style="max-width:1000px;margin:20px auto;padding:0 20px">
      <% if notice %>
        <div style="background:#d4edda;color:#155724;padding:10px;border-radius:4px;margin-bottom:15px"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div style="background:#f8d7da;color:#721c24;padding:10px;border-radius:4px;margin-bottom:15px"><%= alert %></div>
      <% end %>
      <%= yield %>
    </div>
  </body>
</html>